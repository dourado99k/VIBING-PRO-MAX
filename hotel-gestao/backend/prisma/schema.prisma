generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
}

enum AlertType {
  LOW_AVAILABILITY
  NEAR_FULL_OCCUPANCY
  OVERBOOKING_BLOCKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reservationsCreated Reservation[] @relation("ReservationCreatedBy")
  auditLogs           AuditLog[]
  alertsAcknowledged  AvailabilityAlert[] @relation("AlertAcknowledgedBy")
}

model HotelSettings {
  id                    String   @id @default(cuid())
  minRoomsAvailableWarn Int      @default(3)
  occupancyWarnPercent  Int      @default(85)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model Room {
  id          String   @id @default(cuid())
  number      String   @unique
  name        String?
  type        String
  capacity    Int      @default(2)
  floor       Int?
  active      Boolean  @default(true)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reservations Reservation[]
}

model Guest {
  id         String   @id @default(cuid())
  fullName   String
  email      String?
  phone      String?
  documentId String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  reservations Reservation[]
}

model Reservation {
  id          String            @id @default(cuid())
  roomId      String
  guestId     String
  checkIn     DateTime
  checkOut    DateTime
  status      ReservationStatus @default(CONFIRMED)
  notes       String?           @db.Text
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  room      Room @relation(fields: [roomId], references: [id], onDelete: Restrict)
  guest     Guest @relation(fields: [guestId], references: [id], onDelete: Restrict)
  createdBy User @relation("ReservationCreatedBy", fields: [createdById], references: [id])

  @@index([roomId, checkIn, checkOut])
  @@index([checkIn, checkOut])
}

model AvailabilityAlert {
  id             String    @id @default(cuid())
  type           AlertType
  message        String    @db.Text
  contextJson    String?   @db.Text
  relatedFrom    DateTime?
  relatedTo      DateTime?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedById String?
  createdAt      DateTime  @default(now())

  acknowledgedBy User? @relation("AlertAcknowledgedBy", fields: [acknowledgedById], references: [id])

  @@index([acknowledged, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String?
  action     String
  details    String?  @db.Text
  userId     String
  performedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entityType, performedAt])
  @@index([performedAt])
}
